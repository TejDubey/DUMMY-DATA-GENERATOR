<!DOCTYPE html>
<html lang="en">
    <head>
        <title>Dummy Data Generator</title>
    </head>
    <body>
        <div style="display: flex; background-color: #fef3c7; align-items: center; justify-content: center; border: 2px solid #f0c54a; border-radius: 10px; color: #ea6a1b;">
            <h1 style="font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif; font-size:40px; font-weight:700; letter-spacing:0.5px;">
                Dummy Data Generator
            </h1>
        </div>
        <br><br><br><br>
        <div style="display: flex; justify-content: center; align-items: center;">
            <div style="display: flex; justify-content: center; align-items: center; background-color: #fae7cf; height: 100px; width: 400px; border: 2px solid #ddb47c; border-radius: 8px;">
                <button
                    style="color: white; background-color: #1f9d55; border: 1px solid #18864a; padding: 9px 14px; border-radius: 5px; font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif; margin: 6px; font-size: 15px; font-weight: 500; cursor: pointer;"
                    id="b1">
                    Generate Now
                </button>
                <button
                    style="color: white; background-color: #1f9d55; border: 1px solid #18864a; padding: 9px 14px; border-radius: 5px; font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif; margin: 6px; font-size: 15px; font-weight: 500; cursor: pointer;"
                    id="b2">
                    Navigate to see your JSON!
                </button>
            </div>
        </div>
        <br><br><br>
    </body>
    <script>
        let div=document.createElement("div")
        div.id="msg"
        div.style.backgroundColor="#dcfce7"
        div.style.color="#166534"
        div.style.height="60px"
        div.style.width="350px"
        div.style.border = "2px solid #22c55e"
        div.style.borderRadius = "10px"
        div.style.display = "flex"
        div.style.alignItems = "center"
        div.style.justifyContent = "center"
        div.style.margin = "20px auto"
        div.style.fontSize = "16px"
        div.style.fontWeight = "600"
        div.style.fontFamily = "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
        div.style.boxShadow = "0 8px 20px rgba(34, 197, 94, 0.25)"
        function showdiv(){
            document.body.appendChild(div)
        }
        document.getElementById("b1").addEventListener("click",async ()=>{
            let n = Number(prompt("Enter number of records to generate: ", 10));
            if(isNaN(n) || n <= 0){
                alert("Please enter a valid positive number");
                return;
            }
            if(n > 5000){
                alert("Maximum 5000 records allowed");
                return;
            }
            let a = await fetch(`/ddg?n=${n}`);
            let b = await a.json()
            div.textContent=`${b.count} records inserted successfully!!`
            showdiv()
            console.log("Button Clicked");
            console.log(b)
        })
        document.getElementById("b2").addEventListener("click",()=>{
            window.location.href="/employees"
        })
    </script>
</html>